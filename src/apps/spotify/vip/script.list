# 歌手与专辑请求适配。
spotify_request=type=http-request,pattern=^https:\/\/(?:spclient\.wg\.spotify\.com|[A-Za-z0-9-]+-spclient\.spotify\.com(?::443)?)\/(?:artistview\/v1\/artist|album-entity-view\/v2\/album)(?:[/?#]|$),requires-body=0,script-path=https://raw.githubusercontent.com/akiralereal/shadowrocket-toolkit/338320b364a0d6fb60fdeb60bb0407627085119b/scripts/spotify-json.js

# 处理账户配置的二进制响应；仅影响客户端可用的部分播放能力。
spotify_response=type=http-response,pattern=^https:\/\/(?:spclient\.wg\.spotify\.com|[A-Za-z0-9-]+-spclient\.spotify\.com(?::443)?)\/(?:bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$,requires-body=1,binary-body-mode=1,max-size=0,script-path=https://raw.githubusercontent.com/akiralereal/shadowrocket-toolkit/338320b364a0d6fb60fdeb60bb0407627085119b/scripts/spotify-proto.js
