#!name=iFansClub - Spotify Lyrics
#!desc=更新时间：2026-07-22 | 非中文歌词翻译（需百度翻译 API 凭据）
#!arguments=appid:,securityKey:
#!arguments-desc=填写自己的百度翻译 API App ID 与密钥；仅保存在本机。

[Script]
spotify_lyrics=type=http-response,pattern=^https:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/(?:[^/?#]+)(?:[/?#]|$),requires-body=1,binary-body-mode=1,max-size=0,timeout=10,script-path=https://raw.githubusercontent.com/akiralereal/shadowrocket-toolkit/338320b364a0d6fb60fdeb60bb0407627085119b/scripts/spotify-lyric.js,argument=appid={{{appid}}}&securityKey={{{securityKey}}}

[MITM]
hostname = %APPEND% spclient.wg.spotify.com
